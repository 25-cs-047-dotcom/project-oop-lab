#include <iostream>
#include <string>
using namespace std;



class Person
{
protected:
    string name;
    string CNIC;
    int age;
    string contact;

public:
    Person(string n, string c, int a, string con)
    {
        name = n;
        CNIC = c;
        age = a;
        contact = con;
    }

    virtual void displayInfo() = 0;  
};



class Student : public Person
{
private:
    int rollNo;
    int semester;
    float GPA;
    string enrolledCourses[3];

public:

    Student(string n, string c, int a, string con,
            int r, int s, float g)
            : Person(n,c,a,con)
    {
        rollNo = r;
        semester = s;
        GPA = g;

        enrolledCourses[0] = "OOP";
        enrolledCourses[1] = "DSA";
        enrolledCourses[2] = "DB";
    }


    void calculateGrade()
    {
        if(GPA >= 3.5)
            cout<<"Grade: A"<<endl;

        else if(GPA >= 3.0)
            cout<<"Grade: B"<<endl;

        else
            cout<<"Grade: C"<<endl;
    }


    void displayInfo() override
    {
        cout<<"\n--- Student Info ---"<<endl;
        cout<<"Name: "<<name<<endl;
        cout<<"CNIC: "<<CNIC<<endl;
        cout<<"Age: "<<age<<endl;
        cout<<"Contact: "<<contact<<endl;
        cout<<"Roll No: "<<rollNo<<endl;
        cout<<"Semester: "<<semester<<endl;
        cout<<"GPA: "<<GPA<<endl;

        cout<<"Courses: ";
        for(int i=0;i<3;i++)
            cout<<enrolledCourses[i]<<" ";

        cout<<endl;

        calculateGrade();
    }
};




class Faculty : public Person
{
private:
    int employeeID;
    string department;
    string designation;
    string assignedCourses;

public:

    Faculty(string n,string c,int a,string con,
            int id,string d,string des,string course)
            :Person(n,c,a,con)
    {
        employeeID=id;
        department=d;
        designation=des;
        assignedCourses=course;
    }


    void displayInfo() override
    {
        cout<<"\n--- Faculty Info ---"<<endl;
        cout<<"Name: "<<name<<endl;
        cout<<"Employee ID: "<<employeeID<<endl;
        cout<<"Department: "<<department<<endl;
        cout<<"Designation: "<<designation<<endl;
        cout<<"Course: "<<assignedCourses<<endl;
    }
};





class Staff : public Person
{
private:
    int staffID;
    string role;
    float salary;


public:

    Staff(string n,string c,int a,string con,
          int id,string r,float s)
          :Person(n,c,a,con)
    {
        staffID=id;
        role=r;
        salary=s;
    }


    void displayInfo() override
    {
        cout<<"\n--- Staff Info ---"<<endl;
        cout<<"Name: "<<name<<endl;
        cout<<"Staff ID: "<<staffID<<endl;
        cout<<"Role: "<<role<<endl;
        cout<<"Salary: "<<salary<<endl;
    }
};




int main()
{

   
    Person* p;


    Student s("Ali","12345",20,"03001234567",
              101,4,3.7);

    Faculty f("Ahmed","98765",40,"031111111",
              201,"CS","Professor","OOP");

    Staff st("Sara","55555",35,"032222222",
             301,"Admin",50000);



    p=&s;
    p->displayInfo();


    p=&f;
    p->displayInfo();


    p=&st;
    p->displayInfo();



    return 0;
}
