#include <iostream>
#include <string>
using namespace std;

//==================== FeeRecord Class ====================
class FeeRecord
{
private:
    string studentRef;
    double semesterFee;
    double hostelFee;
    double libraryFine;
    double totalPaid;
    double balance;

public:
    // Constructor
    FeeRecord(string ref = "", double sem = 0,
              double hostel = 0, double fine = 0)
    {
        studentRef = ref;
        semesterFee = sem;
        hostelFee = hostel;
        libraryFine = fine;

        totalPaid = 0;
        balance = semesterFee + hostelFee + libraryFine;
    }

    // Copy Constructor
    FeeRecord(const FeeRecord& obj)
    {
        studentRef = obj.studentRef;
        semesterFee = obj.semesterFee;
        hostelFee = obj.hostelFee;
        libraryFine = obj.libraryFine;
        totalPaid = obj.totalPaid;
        balance = obj.balance;
    }

    // Copy Assignment Operator
    FeeRecord& operator=(const FeeRecord& obj)
    {
        if (this != &obj)
        {
            studentRef = obj.studentRef;
            semesterFee = obj.semesterFee;
            hostelFee = obj.hostelFee;
            libraryFine = obj.libraryFine;
            totalPaid = obj.totalPaid;
            balance = obj.balance;
        }

        return *this;
    }

    // Operator -= for payment
    void operator-=(double payment)
    {
        totalPaid += payment;
        balance -= payment;

        if (balance < 0)
            balance = 0;
    }

    void display()
    {
        cout << "\nStudent ID : " << studentRef << endl;
        cout << "Semester Fee : " << semesterFee << endl;
        cout << "Hostel Fee : " << hostelFee << endl;
        cout << "Library Fine : " << libraryFine << endl;
        cout << "Total Paid : " << totalPaid << endl;
        cout << "Balance : " << balance << endl;
    }
};

//==================== Invoice Class ====================
class Invoice
{
private:
    int invoiceID;
    string date;
    string* items;
    int itemCount;
    double totalAmount;

    static int invoiceCounter;

public:
    // Constructor
    Invoice(string d, int count, double amount)
    {
        invoiceID = ++invoiceCounter;

        date = d;
        itemCount = count;
        totalAmount = amount;

        items = new string[itemCount];

        cout << "\nEnter " << itemCount << " items:\n";

        for (int i = 0; i < itemCount; i++)
        {
            cout << "Item " << i + 1 << ": ";
            cin >> items[i];
        }
    }

    void display()
    {
        cout << "\nInvoice ID : " << invoiceID << endl;
        cout << "Date : " << date << endl;

        cout << "Items : ";
        for (int i = 0; i < itemCount; i++)
        {
            cout << items[i] << " ";
        }

        cout << "\nTotal Amount : " << totalAmount << endl;
    }

    // Destructor
    ~Invoice()
    {
        delete[] items;
        cout << "\nInvoice " << invoiceID
             << " memory released successfully.\n";
    }
};

// Static Member Initialization
int Invoice::invoiceCounter = 0;

//==================== Main Function ====================
int main()
{
    // Fee Record Object
    FeeRecord f1("22-CS-101", 50000, 12000, 3000);

    cout << "Original Fee Record\n";
    f1.display();

    // Payment using -= operator
    f1 -= 20000;

    cout << "\nAfter Paying 20000\n";
    f1.display();

    // Copy Constructor
    FeeRecord f2(f1);

    cout << "\nCopied Fee Record\n";
    f2.display();

    // Assignment Operator
    FeeRecord f3;
    f3 = f1;

    cout << "\nAssigned Fee Record\n";
    f3.display();

    // Invoice Objects
    Invoice i1("01-12-2025", 2, 15000);
    Invoice i2("02-12-2025", 3, 25000);

    cout << "\nInvoice 1 Details";
    i1.display();

    cout << "\nInvoice 2 Details";
    i2.display();

    return 0;
}
